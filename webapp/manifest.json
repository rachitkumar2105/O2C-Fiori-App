{
  "_version": "1.21.0",
  "sap.app": {
    "id": "com.globaltrade.o2c",
    "type": "application",
    "title": "GlobalTrade O2C Manager",
    "description": "Order-to-Cash Management Application for GlobalTrade Enterprises",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/SD_O2C_SRV/",
        "type": "OData",
        "settings": { "odataVersion": "2.0" }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": { "icon": "sap-icon://sales-order" },
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.fiori": {
    "registrationIds": ["F1234"],
    "archeType": "transactional"
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.globaltrade.o2c.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.108.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.suite.ui.commons": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": { "useBatch": false }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "com.globaltrade.o2c.i18n.i18n" }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.globaltrade.o2c.view",
        "controlId": "appNav",
        "controlAggregation": "pages",
        "bypassed": { "target": "notFound" }
      },
      "routes": [
        { "name": "home",           "pattern": "",                        "target": "home" },
        { "name": "salesOrderList", "pattern": "salesorders",             "target": "salesOrderList" },
        { "name": "createOrder",    "pattern": "salesorders/create",      "target": "createOrder" },
        { "name": "orderDetail",    "pattern": "salesorders/{orderId}",   "target": "orderDetail" },
        { "name": "delivery",       "pattern": "delivery/{orderId}",      "target": "delivery" },
        { "name": "invoice",        "pattern": "invoice/{orderId}",       "target": "invoice" }
      ],
      "targets": {
        "home":           { "viewName": "Home",           "viewLevel": 1 },
        "salesOrderList": { "viewName": "SalesOrderList", "viewLevel": 2 },
        "createOrder":    { "viewName": "CreateOrder",    "viewLevel": 3 },
        "orderDetail":    { "viewName": "OrderDetail",    "viewLevel": 3 },
        "delivery":       { "viewName": "DeliveryTracker","viewLevel": 4 },
        "invoice":        { "viewName": "InvoiceView",    "viewLevel": 5 },
        "notFound":       { "viewName": "NotFound",       "viewLevel": 1 }
      }
    }
  }
}
